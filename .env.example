# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#   nano .env          # fill in GOOGLE_API_KEY and Redis details
#   docker compose up --build -d

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Google Generative AI API key (used for embeddings + LLM responses)
GOOGLE_API_KEY=your_google_api_key_here

# ---------------------------------------------------------------------------
# External Redis (not managed by Docker Compose)
# ---------------------------------------------------------------------------
REDIS_HOST=your_redis_host_here
REDIS_PORT=6379
REDIS_DB=0
# Leave blank if your Redis has no password
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Flask server
# ---------------------------------------------------------------------------
PORT=7700
FLASK_DEBUG=0

# Only allow requests from the frontend domain
CORS_ORIGINS=https://tutorai.aditya-raj.site
